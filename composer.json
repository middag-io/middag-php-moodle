{
  "name": "middag-io/moodle",
  "description": "MIDDAG Moodle adapter — platform bindings, ACL layer, and Moodle-specific implementations for middag-framework",
  "type": "library",
  "license": "Apache-2.0",
  "keywords": [
    "moodle",
    "adapter",
    "host-adapter",
    "mform",
    "xmldb",
    "inertia",
    "middag",
    "plugin"
  ],
  "homepage": "https://github.com/middag-io/middag-php-moodle",
  "support": {
    "issues": "https://github.com/middag-io/middag-php-moodle/issues",
    "source": "https://github.com/middag-io/middag-php-moodle",
    "security": "https://github.com/middag-io/middag-php-moodle/security/policy"
  },
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "firebase/php-jwt": "^7.0",
    "middag-io/framework": "^1.7",
    "middag-io/ui": "^1.3",
    "nyholm/psr7": "^1.8",
    "psr/container": "^2.0",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0",
    "symfony/dependency-injection": "^7.0",
    "symfony/event-dispatcher-contracts": "^3.0",
    "symfony/http-client": "^7.0",
    "symfony/http-foundation": "^7.0",
    "symfony/routing": "^7.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "michaelmeneses/moodle-stubs": "~5.0.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "rector/rector": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Middag\\Moodle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Middag\\Moodle\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-install-cmd": "git config core.hooksPath .githooks 2>/dev/null || true",
    "post-update-cmd": "git config core.hooksPath .githooks 2>/dev/null || true",
    "check": [
      "@check:style",
      "@check:rector",
      "@check:stan"
    ],
    "check:style": "php-cs-fixer fix --dry-run --verbose --config=.php-cs-fixer.dist.php",
    "check:rector": "rector process --dry-run --config=.php-rector.php",
    "check:stan": "phpstan analyse --configuration=.phpstan.neon --memory-limit=512M",
    "fix": [
      "@fix:style",
      "@fix:rector"
    ],
    "fix:all": [
      "@fix:style",
      "@fix:rector",
      "@fix:style"
    ],
    "fix:style": "php-cs-fixer fix --verbose --show-progress=none --config=.php-cs-fixer.dist.php",
    "fix:rector": "rector process --config=.php-rector.php --no-progress-bar",
    "test": "phpunit",
    "test:cov": "XDEBUG_MODE=coverage phpunit --coverage-text",
    "lint:php82": "bin/lint-php82.sh"
  }
}
